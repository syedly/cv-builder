# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-cv-builder

# Auth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# OpenAI (system key for 3 free trials - users can bring their own)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Encryption key for BYOK API keys (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64-char-hex-string-here
